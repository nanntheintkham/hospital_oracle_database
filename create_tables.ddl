    prescribed_date DATE,
    dosage_qty      NUMBER NOT NULL,
    duration_days   NUMBER NOT NULL,
    instructions    VARCHAR2(300)
);

ALTER TABLE prescriptions ADD CHECK ( dosage_qty > 0 );

ALTER TABLE prescriptions ADD CHECK ( duration_days > 0 );

ALTER TABLE prescriptions ADD CONSTRAINT prescriptions_pk PRIMARY KEY ( prescription_id );

