CREATE TABLE appointments (
    appt_id        NUMBER          PRIMARY KEY,
    patient_id     NUMBER          NOT NULL REFERENCES patients(patient_id),
    doctor_id      NUMBER          NOT NULL REFERENCES doctors(doctor_id),
    appt_date      DATE            NOT NULL,         
    appt_duration  NUMBER          DEFAULT 30        
                   CHECK (appt_duration IN (15, 30, 45, 60)),
    status         VARCHAR2(20)    DEFAULT 'SCHEDULED'
                   CHECK (status IN ('SCHEDULED','COMPLETED','CANCELLED','NO_SHOW')),
    reason         VARCHAR2(200),                    
    notes          VARCHAR2(500),                                        
    created_at     DATE            DEFAULT SYSDATE
);

ALTER TABLE appointments
    ADD
        CHECK ( status IN ( 'CANCELLED', 'COMPLETED', 'NO_SHOW', 'SCHEDULED' ) );

ALTER TABLE appointments ADD CONSTRAINT appointments_pk PRIMARY KEY ( appt_id );

CREATE TABLE departments (
    dept_id        NUMBER NOT NULL,
    dept_name      VARCHAR2(50),
    location       VARCHAR2(50),
    head_doctor_id NUMBER
);

ALTER TABLE departments ADD CONSTRAINT departments_pk PRIMARY KEY ( dept_id );

CREATE TABLE doctors (
    doctor_id      NUMBER NOT NULL,
    first_name     VARCHAR2(50) NOT NULL,
    last_name      VARCHAR2(50) NOT NULL,
    specialization VARCHAR2(100),
    dept_id        NUMBER NOT NULL,
    license_number VARCHAR2(30) NOT NULL,
    hire_date      DATE DEFAULT sysdate,
    is_active      CHAR(1) DEFAULT 'Y'
);

ALTER TABLE doctors
    ADD CHECK ( is_active IN ( 'N', 'Y' ) );

ALTER TABLE doctors ADD CONSTRAINT doctors_pk PRIMARY KEY ( doctor_id );

ALTER TABLE doctors ADD CONSTRAINT doctors__un UNIQUE ( license_number );

CREATE TABLE medical_records (
    record_id   NUMBER        PRIMARY KEY,
    patient_id  NUMBER        NOT NULL REFERENCES patients(patient_id),
    doctor_id   NUMBER        NOT NULL REFERENCES doctors(doctor_id),
    visit_date  DATE          DEFAULT SYSDATE,
    diagnosis   VARCHAR2(500) NOT NULL,
    treatment   VARCHAR2(500),
    severity    VARCHAR2(20)  DEFAULT 'MODERATE'
                              CHECK (severity IN ('MILD','MODERATE','SEVERE','CRITICAL')),
    follow_up   DATE,
    notes       VARCHAR2(1000)
)
ORGANIZATION INDEX;

CREATE TABLE medications (
    medication_id NUMBER NOT NULL,
    med_name      VARCHAR2(150) NOT NULL,
    category      VARCHAR2(80),
    unit          VARCHAR2(20) DEFAULT 'mg',
    unit_price    NUMBER(10, 2),
    stock_qty     NUMBER DEFAULT 0,
    updated_at    DATE DEFAULT sysdate
);

ALTER TABLE medications ADD CHECK ( stock_qty > 0 );

ALTER TABLE medications ADD CONSTRAINT medications_pk PRIMARY KEY ( medication_id );

CREATE TABLE patients (
    patient_id       NUMBER          PRIMARY KEY,
    first_name       VARCHAR2(50)    NOT NULL,
    last_name        VARCHAR2(50)    NOT NULL,
    date_of_birth    DATE            NOT NULL,
    gender           CHAR(1)         CHECK (gender IN ('M','F','O')),
    blood_type       VARCHAR2(5),
    phone            VARCHAR2(20),
    email            VARCHAR2(100),
    address          VARCHAR2(255),
    admission_date   DATE            DEFAULT SYSDATE,
    assigned_doctor  NUMBER          REFERENCES doctors(doctor_id),
    is_active        CHAR(1)         DEFAULT 'Y' CHECK (is_active IN ('Y','N'))
)
PARTITION BY RANGE (admission_date) (
    PARTITION p_before_2022 VALUES LESS THAN (DATE '2022-01-01'),
    PARTITION p_2022        VALUES LESS THAN (DATE '2023-01-01'),
    PARTITION p_2023        VALUES LESS THAN (DATE '2024-01-01'),
    PARTITION p_2024        VALUES LESS THAN (DATE '2025-01-01'),
    PARTITION p_2025_plus   VALUES LESS THAN (MAXVALUE)
);

ALTER TABLE patients
    ADD
        CHECK ( gender IN ( 'F', 'M', 'O' ) );

ALTER TABLE patients
    ADD CHECK ( is_active IN ( 'N', 'Y' ) );

ALTER TABLE patients ADD CONSTRAINT patients_pk PRIMARY KEY ( patient_id );

CREATE TABLE prescriptions (
    prescription_id NUMBER NOT NULL,
